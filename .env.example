# Postgres connection string (Neon, Render Postgres, or local).
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Gmail — sends via the Gmail REST API over HTTPS (OAuth2), not SMTP, since
# many hosts (Render's free tier included) block outbound SMTP entirely.
# Set up: create an OAuth 2.0 "Desktop app" Client ID at
# console.cloud.google.com (Gmail API enabled, sending account added as an
# OAuth consent screen test user), then run
#   GMAIL_CLIENT_ID=... GMAIL_CLIENT_SECRET=... node scripts/get-gmail-refresh-token.js
# to get GMAIL_REFRESH_TOKEN.
GMAIL_USER=your-club-account@gmail.com
GMAIL_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=xxxxxxxxxxxxxxxx
GMAIL_REFRESH_TOKEN=xxxxxxxxxxxxxxxx

# Optional — sender address shown to recipients. Defaults to GMAIL_USER if unset.
EMAIL_FROM=Wine Circle <your-club-account@gmail.com>

# Comma-separated list of allowed CORS origins in production.
# Not needed in development (defaults to allow-all).
ALLOWED_ORIGINS=https://your-app.onrender.com

PORT=5000
NODE_ENV=production
